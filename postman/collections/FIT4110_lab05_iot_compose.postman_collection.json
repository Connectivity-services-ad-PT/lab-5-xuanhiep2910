{
  "info": {
    "_postman_id": "a1b2c3d4-lab05-iot-compose-readiness",
    "name": "FIT4110 Lab05 - IoT Ingestion Compose Stack",
    "description": "Postman collection kiểm thử API IoT Ingestion chạy trong Docker Compose stack Lab 05.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "01_Health",
      "item": [
        {
          "name": "GET /health",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Health payload is valid', function () {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body.status).to.eql('ok');",
                  "    pm.expect(body.service).to.eql('iot-ingestion');",
                  "    pm.expect(body.version).to.be.a('string');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/health"
          }
        }
      ]
    },
    {
      "name": "02_Readings_Functional",
      "item": [
        {
          "name": "POST /readings - valid temperature",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 201', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "pm.test('Reading created', function () {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body.accepted).to.eql(true);",
                  "    pm.expect(body.reading_id).to.match(/^R-[0-9]{8}-[0-9]{4}$/);",
                  "    pm.collectionVariables.set('readingId', body.reading_id);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"device_id\": \"ESP32-LAB-A01\",\n  \"metric\": \"temperature\",\n  \"value\": 31.5,\n  \"unit\": \"celsius\",\n  \"timestamp\": \"2026-05-13T08:30:00+07:00\"\n}"
            },
            "url": "{{baseUrl}}/readings"
          }
        },
        {
          "name": "GET /readings/latest",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Latest readings returned', function () {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body.items).to.be.an('array');",
                  "    pm.expect(body.items.length).to.be.at.least(1);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/readings/latest?device_id=ESP32-LAB-A01&limit=5",
              "host": ["{{baseUrl}}"],
              "path": ["readings", "latest"],
              "query": [
                {
                  "key": "device_id",
                  "value": "ESP32-LAB-A01"
                },
                {
                  "key": "limit",
                  "value": "5"
                }
              ]
            }
          }
        },
        {
          "name": "GET /readings/{reading_id}",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Reading detail returned', function () {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body.reading_id).to.eql(pm.collectionVariables.get('readingId'));",
                  "    pm.expect(body.device_id).to.eql('ESP32-LAB-A01');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "url": "{{baseUrl}}/readings/{{readingId}}"
          }
        }
      ]
    },
